<configuration>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level [%thread] %logger{40} - %msg%n%ex{short}</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

    <logger name="org.ncmmis.batch" level="DEBUG"/>

    <logger name="org.springframework.batch" level="INFO"/>
    <logger name="org.springframework.jdbc.core" level="WARN"/>
    <logger name="org.springframework.transaction" level="WARN"/>

    <!-- Enable temporarily when debugging Spring Batch metadata SQL. -->
    <!--
    <logger name="org.springframework.batch.core.repository.dao" level="DEBUG"/>
    <logger name="org.springframework.jdbc.core.JdbcTemplate" level="DEBUG"/>
    <logger name="org.springframework.jdbc.core.StatementCreatorUtils" level="TRACE"/>
    <logger name="org.springframework.transaction" level="DEBUG"/>
    -->
</configuration>
